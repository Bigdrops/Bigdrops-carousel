# macOS
.DS_Store
**/.DS_Store

# Video render temp (render-video.js artifacts)
.video-tmp-*/
**/.video-tmp-*/

# Personal asset index (personal real data, keep only .example.json template)
assets/personal-asset-index.json

# Environment variables (API keys and other sensitive info, keep only .env.example template)
.env
.env.local

# Voiceover working directory (TTS mp3, timeline.json temporary artifacts, can be regenerated)
**/_narration/
**/_narration_*/

# Node / editor / OS
node_modules/
*.swp
.idea/
.vscode/
Thumbs.db

# Verification artifacts (screenshots, temporary test scripts)
demos/_frames_*.png
demos/_verify.js
demos/_verify.mjs

# Development/test intermediate artifacts (for internal skill development, not distributed to users)
_style-research/
**/design-demos/

# Demo large videos (distributed via GitHub Releases, not committed to repo to avoid bloat)
demos/**/*.mp4
